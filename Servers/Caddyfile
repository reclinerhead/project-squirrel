# Pearl's front door (issue #141, epic #110 Phase 1).
#
# Canonical copy lives in the repo at Servers/Caddyfile; the live copy is
# /etc/caddy/Caddyfile on pearl. Keep them in sync when this changes:
#
#     sudo cp ~/project-squirrel/Servers/Caddyfile /etc/caddy/Caddyfile
#     sudo systemctl reload caddy
#
# LAN-only, plain HTTP on purpose — TLS/auth is the epic's Deferred section
# and arrives (if ever) here, at this one choke point, without touching any
# app behind it.

{
	auto_https off
}

# The pearl host itself — however it was typed. A browser sends the name the
# user typed as the Host header ("pearl" resolves via the .lan search domain,
# but the header still says "pearl"), so all three spellings are listed.
http://pearl, http://pearl.lan, http://192.168.1.64 {
	# The Mole hole (Pi-hole's admin). The web server itself sits on
	# loopback:8081 (Phase 1) — this proxy is the only way in, which is the
	# point. The UI lives at /mole natively (webserver.paths.webhome is
	# "/mole/" in pihole.toml — set via
	# `sudo pihole-FTL --config webserver.paths.webhome '/mole/'`), so no
	# path rewriting happens here. /api is the Pi-hole v6 API the admin UI
	# calls (its path doesn't follow webhome); it must ride along or the
	# admin loads as an empty shell.
	handle /mole* {
		reverse_proxy 127.0.0.1:8081
	}
	handle /api* {
		reverse_proxy 127.0.0.1:8081
	}

	# The Homestead launchpad (issue #143): the front door's face, static
	# files served straight from the checkout. A merge deploys it by pull
	# alone -- there is no build, so autodeploy needs no gate for it, and
	# "it deploys by doing nothing" is correct, not broken.
	redir /home /home/ 308
	handle_path /home/* {
		root * /home/todd/project-squirrel/launchpad
		file_server
	}

	# The bookmarkable front door: pearl -> the porch.
	redir / /home/ 302
}

# The MCC dashboard. Type "mcc/" on a desktop and the .lan suffix does the
# rest; phones use the full name.
http://mcc, http://mcc.lan {
	reverse_proxy 127.0.0.1:3000
}

# The music app.
http://music, http://music.lan {
	reverse_proxy 127.0.0.1:3001
}

# Frigate, the NVR (epic #243). Its own hostname rather than a pearl/frigate
# path because Frigate's UI does not survive subpath serving (absolute asset
# URLs). Frigate speaks TLS on 8971 with a self-signed cert, so this is the
# one upstream Caddy talks https to — skip-verify is fine on loopback. The
# house stays plain HTTP out front; Frigate's own login rides through it
# (its auth cookie is not Secure-flagged by default, so http works).
http://frigate, http://frigate.lan {
	reverse_proxy https://127.0.0.1:8971 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}
