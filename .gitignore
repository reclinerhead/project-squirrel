# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Merle daemon's local SQLite database (mutable state -- never committed)
*.db
*.db-wal
*.db-shm

# Weather service's rolling 48h window (mutable state on pearl -- see weather.py)
weather_history.json

# Event still-shot archive (frame_archiver.py's default MERLE_FRAMES_DIR on
# pearl). ANCHORED to the repo root: a bare "frames/" also matches
# mcc/app/frames/ and silently kept the /frames route out of git (the #90
# deploy mystery).
/frames/

# Datasets, captures, and model weights -- large binaries stay out of git.
# (Datasets live in Roboflow + local disk; weights are reproducible from training.)
runs/
training/
hard_frames/
debug_frames/
snapshots/
unknowns/
*.pt
*.jpg
*.mp4
*.cache

# Node / Next.js (mcc/ has its own .gitignore; this is belt-and-suspenders)
node_modules/
.pnp
.pnp.js
coverage/
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
.DS_Store
*.pem
.vercel

# Local machine config and secrets
.claude/
.env*
